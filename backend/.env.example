# Dummar Backend — Environment Variables Example
#
# DO NOT copy this file as-is into production. Generate strong random secrets.
# DO NOT commit a real .env to git.
#
# Quick generation:
#   SECRET_KEY=$(python3 -c "import secrets; print(secrets.token_urlsafe(48))")
#   DB_PASSWORD=$(python3 -c "import secrets; print(secrets.token_urlsafe(24))")
#
# When the stack is launched via ./deploy.sh from the repository root, deploy.sh
# auto-generates a safe .env at the repo root with strong secrets if one is missing.
# This file (backend/.env.example) only documents the variables the backend reads
# directly when running OUTSIDE Docker (e.g. local uvicorn).

# Database (host/port/user composed in DATABASE_URL)
DATABASE_URL=postgresql://dummar:CHANGE_ME_STRONG_PASSWORD@db:5432/dummar_db

# JWT signing key — MUST be 32+ random characters. NEVER use a literal value.
SECRET_KEY=REPLACE_WITH_RANDOM_32+_CHARS

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
UPLOAD_DIR=/app/uploads
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Production hardening
# ENVIRONMENT=production disables Swagger UI / ReDoc / openapi.json by default.
# Set ENABLE_API_DOCS=true to re-enable them (e.g. behind a reverse-proxy auth layer).
ENVIRONMENT=production
ENABLE_API_DOCS=false

LOG_LEVEL=info

# Email (optional — in-app notifications work without email)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@dummar.gov.sy

# =============================================================================
# Dummar Project Management — Frontend Build-time Environment
# =============================================================================
# Vite bakes VITE_* variables into the production bundle at BUILD time (not at
# runtime). These values end up embedded in dist/assets/*.js. Do not put
# secrets here.
#
# Copy this file to .env (or .env.production) and adjust for your deployment.
# If unset, the defaults in src/config.ts are already production-safe
# (same-origin, no localhost fallback).
# =============================================================================

# Base URL of the backend API (no trailing slash).
# Production-safe value: `/api`. nginx proxies /api/* to the backend, so the
# bundle can run on any host/scheme/port without rebuilds. DO NOT set this to
# http://localhost:8000 for a production build — login/auth will break.
VITE_API_BASE_URL=/api

# Base URL used to build public file URLs returned by the backend as
# root-relative paths (e.g. /uploads/contracts/foo.pdf).
# Leave empty for same-origin (nginx serves /uploads/*). Only override when
# the dev frontend is talking to a directly-exposed backend on another host.
VITE_FILES_BASE_URL=
